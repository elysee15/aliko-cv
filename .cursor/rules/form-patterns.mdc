# Form Patterns

All forms in this project use **`useHookFormAction`** from `@next-safe-action/adapter-react-hook-form` with **zodResolver** and the design system's `Field` components. This combines `useForm` + `useAction` into a single hook, automatically mapping server validation errors to form fields. Ensures consistent validation, accessibility (UX-DR10, UX-DR14), and error handling.

## 1. Required Stack

```tsx
import { useHookFormAction } from "@next-safe-action/adapter-react-hook-form/hooks";
import { zodResolver } from "@hookform/resolvers/zod";
```

Field components from the design system:

```tsx
import {
  Field,
  FieldDescription,
  FieldError,
  FieldGroup,
  FieldLabel,
} from "@workspace/ui/components/field";
import { Input } from "@workspace/ui/components/input";
import { Button } from "@workspace/ui/components/button";
```

## 2. Schema Convention

Zod schemas live in `apps/web/lib/schemas/*.ts`. The **same schema** is shared between the server action's `.inputSchema()` and the form's `zodResolver()` so client and server validation stay in sync.

- Use `z.strictObject()` for form schemas (rejects unknown properties)
- Export the inferred type alongside the schema
- Use `.refine()` for cross-field validation (e.g. password confirmation) with `path` targeting the error field
- Validation messages in French

```ts
import { z } from "zod";

export const myFormSchema = z.strictObject({
  name: z.string().min(1, "Le nom est requis").max(200),
  email: z.string().min(1, "L'email est requis").email("Format d'email invalide"),
});

export type MyFormInput = z.infer<typeof myFormSchema>;
```

## 3. Component Structure

`useHookFormAction` returns four properties:

| Property | Description |
|---|---|
| `form` | Full `UseFormReturn` — `form.register()`, `form.formState.errors`, `form.setFocus()`, etc. |
| `action` | Full `UseActionHookReturn` — `action.isPending`, `action.result`, `action.hasSucceeded`, etc. |
| `handleSubmitWithAction` | Pass directly to `<form onSubmit={...}>` — handles client validation then server execution |
| `resetFormAndAction` | Resets both form fields and action state |

```tsx
"use client";

import { useHookFormAction } from "@next-safe-action/adapter-react-hook-form/hooks";
import { zodResolver } from "@hookform/resolvers/zod";
import { myAction } from "@/app/actions/my-action";
import { myFormSchema } from "@/lib/schemas/my-form";
// ... UI imports ...

export function MyForm({ defaultName }: { defaultName: string }) {
  const { form, action, handleSubmitWithAction, resetFormAndAction } =
    useHookFormAction(myAction, zodResolver(myFormSchema), {
      formProps: {
        defaultValues: { name: defaultName, email: "" },
      },
      actionProps: {
        onSuccess: ({ data }) => {
          toast.success("Enregistré");
          resetFormAndAction();
        },
        onError: ({ error }) => {
          toast.error(error.serverError ?? "Erreur");
        },
      },
    });

  const { errors } = form.formState;

  return (
    <form
      onSubmit={handleSubmitWithAction}
      noValidate
      className="flex flex-col gap-4"
    >
      {action.result.serverError ? (
        <div role="alert" className="rounded-md border border-destructive/50 bg-destructive/10 px-3 py-2 text-sm text-destructive">
          {action.result.serverError}
        </div>
      ) : null}

      <FieldGroup className="gap-4">
        <Field data-invalid={!!errors.name}>
          <FieldLabel htmlFor="my-form-name">
            Nom <span className="text-destructive" aria-hidden>*</span>
          </FieldLabel>
          <Input
            id="my-form-name"
            aria-required="true"
            aria-invalid={!!errors.name}
            aria-describedby={errors.name ? "my-form-name-error" : undefined}
            className={errors.name ? "border-destructive" : undefined}
            disabled={action.isPending}
            {...form.register("name")}
          />
          {errors.name ? (
            <FieldError id="my-form-name-error">{errors.name.message}</FieldError>
          ) : null}
        </Field>

        <Field data-invalid={!!errors.email}>
          <FieldLabel htmlFor="my-form-email">
            Email <span className="text-destructive" aria-hidden>*</span>
          </FieldLabel>
          <Input
            id="my-form-email"
            type="email"
            aria-required="true"
            aria-invalid={!!errors.email}
            aria-describedby={errors.email ? "my-form-email-error" : undefined}
            className={errors.email ? "border-destructive" : undefined}
            disabled={action.isPending}
            {...form.register("email")}
          />
          {errors.email ? (
            <FieldError id="my-form-email-error">{errors.email.message}</FieldError>
          ) : null}
        </Field>
      </FieldGroup>

      <Button type="submit" className="w-full min-h-11" disabled={action.isPending}>
        {action.isPending ? "Envoi…" : "Envoyer"}
      </Button>
    </form>
  );
}
```

## 4. Mandatory Accessibility Checklist (UX-DR10 / UX-DR14)

Every form field MUST have:

| Attribute | Purpose | Example |
|---|---|---|
| `<FieldLabel htmlFor="...">` | Visible label tied to the input | Always present, never hidden |
| `<span className="text-destructive" aria-hidden>*</span>` | Required indicator | Inside the label for required fields |
| `aria-required="true"` | Announces required to screen readers | On the `<Input>` |
| `aria-invalid={!!errors.field}` | Announces invalid state | On the `<Input>`, conditional |
| `aria-describedby="error-id"` | Links input to its error message | Points to `<FieldError id="...">` when error exists |
| `<FieldError id="...">` | Error message below the field | Conditionally rendered |
| `disabled={action.isPending}` | Prevents double-submit | On the `<Input>` and `<Button>` |

Every `<form>` MUST have:

| Attribute | Purpose |
|---|---|
| `noValidate` | Disables browser validation — Zod handles everything |
| `onSubmit={handleSubmitWithAction}` | Client validation → server execution with auto-mapped errors |

Every primary/destructive button MUST have:

| Attribute | Purpose |
|---|---|
| `min-h-11` (or `className="min-h-11"`) | 44px touch target (UX-DR14) |

## 5. Error Handling

Two error channels — never mix them:

| Error type | Where | How |
|---|---|---|
| **Field validation** (Zod + server) | Below the field | `<FieldError>` with `form.formState.errors.field.message` — includes both client-side and server-side validation errors (auto-mapped by the adapter) |
| **Server errors** (unexpected) | Above the form or via `onError` callback | `action.result.serverError` with `role="alert"`, or `toast.error()` in `actionProps.onError` |

```tsx
// GOOD: Field error below the input (covers both client + server validation)
{errors.email ? (
  <FieldError id="email-error">{errors.email.message}</FieldError>
) : null}

// GOOD: Server error above the form
{action.result.serverError ? (
  <div role="alert" className="...text-destructive">{action.result.serverError}</div>
) : null}

// GOOD: Server error via callback (toast for non-field errors)
actionProps: {
  onError: ({ error }) => { toast.error(error.serverError ?? "Erreur"); },
}

// BAD: Using toast for validation errors
toast.error(errors.email.message); // Never do this

// BAD: Using useState for globalError — use action.result.serverError instead
const [globalError, setGlobalError] = useState<string | null>(null);
```

Use `toast.success()` for success feedback (save confirmed, item created). Never use `toast.error()` for field validation — only for unexpected server errors in non-form contexts.

## 6. When `useAction` Alone Is Sufficient

For **single-field forms** (e.g. API key creation), `useAction` from `next-safe-action/hooks` is sufficient — `useHookFormAction` is overkill.

```tsx
const action = useAction(createApiKeyAction, {
  onSuccess: ({ data }) => { /* ... */ },
  onError: ({ error }) => { toast.error(error.serverError ?? "Erreur"); },
});

// Validation error from inputSchema
const nameError = action.result.validationErrors?.name?._errors?.[0];
```

Still apply the same accessibility attributes:

```tsx
<Label htmlFor="field-id">
  Label <span className="text-destructive">*</span>
</Label>
<Input
  id="field-id"
  aria-required="true"
  aria-invalid={nameError ? true : undefined}
  aria-describedby={nameError ? "field-error-id" : undefined}
/>
{nameError && (
  <p id="field-error-id" role="alert" className="mt-1 text-xs text-destructive">
    {nameError}
  </p>
)}
```

## 7. Anti-Patterns

```tsx
// BAD: Using standalone useForm + manual onSubmit for server actions
const { register, handleSubmit } = useForm({ resolver: zodResolver(schema) });
async function onSubmit(values) { await myAction(values); }
<form onSubmit={handleSubmit(onSubmit)}>

// GOOD: useHookFormAction combines useForm + useAction and auto-maps server errors
const { form, action, handleSubmitWithAction } = useHookFormAction(myAction, zodResolver(schema), { ... });
<form onSubmit={handleSubmitWithAction}>

// BAD: Raw FormData without Zod validation
async function onSubmit(e: FormEvent) {
  const fd = new FormData(e.target);
  await fetch("/api/...", { body: fd });
}

// BAD: Missing noValidate — browser popups conflict with FieldError
<form onSubmit={handleSubmitWithAction}>

// GOOD: Always add noValidate
<form onSubmit={handleSubmitWithAction} noValidate>

// BAD: Using useState for globalError or individual field errors
const [globalError, setGlobalError] = useState("");
const [emailError, setEmailError] = useState("");

// GOOD: Server errors from action.result, field errors from form.formState.errors
{action.result.serverError && <div role="alert">{action.result.serverError}</div>}
{form.formState.errors.email && <FieldError>{form.formState.errors.email.message}</FieldError>}

// BAD: Shared isPending across multiple actions
const [isPending, startTransition] = useTransition();

// GOOD: Each useHookFormAction/useAction has its own action.isPending
const createForm = useHookFormAction(createAction, zodResolver(schema), { ... });
const deleteAction = useAction(deleteAction, { ... });
```

## 8. FieldDescription for Hints

Use `<FieldDescription>` for input hints (password rules, format expectations). Link it via `aria-describedby` alongside the error:

```tsx
<Input
  aria-describedby={
    errors.password
      ? "password-error password-hint"
      : "password-hint"
  }
  {...form.register("password")}
/>
<FieldDescription id="password-hint">
  Au moins 8 caractères, une majuscule, une minuscule et un chiffre.
</FieldDescription>
{errors.password ? (
  <FieldError id="password-error">{errors.password.message}</FieldError>
) : null}
```
