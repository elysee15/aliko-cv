# Database (used by packages/db and Better Auth)
POSTGRES_URL=postgresql://user:password@localhost:5432/aliko_cv
# Or use DATABASE_URL if you prefer:
# DATABASE_URL=postgresql://user:password@localhost:5432/aliko_cv

# Better Auth (used by apps/web for sign-up, sign-in, session)
BETTER_AUTH_SECRET=your-secret-at-least-32-chars
# Must match the URL you use to open the app (e.g. http://localhost:3001 if dev runs on 3001).
# In development, localhost:3000 and localhost:3001 are allowed via trustedOrigins.
BETTER_AUTH_URL=http://localhost:3000
# Same origin as BETTER_AUTH_URL for browser calls (sign-in, password reset, etc.)
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Optional — password reset emails (Better Auth sendResetPassword)
# Without RESEND_API_KEY, the reset URL is logged on the server in development.
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=Aliko CV <onboarding@resend.dev>
